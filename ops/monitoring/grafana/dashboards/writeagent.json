{
  "title": "WriteAgent",
  "uid": "writeagent-overview",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Health Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "expr": "writeagent_health_status",
          "legendFormat": "Health"
        }
      ]
    },
    {
      "id": 2,
      "title": "Scene Generation Failures (rate/10m)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 0.01 }
          ]
        }
      },
      "targets": [
        {
          "expr": "rate(writeagent_scene_generation_failures_total[10m])",
          "legendFormat": "Failure rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "Audit Log Failures (rate/10m)",
      "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 0.001 }
          ]
        }
      },
      "targets": [
        {
          "expr": "rate(writeagent_audit_log_failures_total[10m])",
          "legendFormat": "Failure rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Contradictions Detected (rate/30m)",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(writeagent_contradictions_total[30m]))",
          "legendFormat": "Contradiction rate"
        }
      ]
    },
    {
      "id": 5,
      "title": "LLM Call Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (agent_id, le) (rate(writeagent_llm_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{agent_id}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (agent_id, le) (rate(writeagent_llm_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{agent_id}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (agent_id, le) (rate(writeagent_llm_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 6,
      "title": "LLM Tokens / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (agent_id, direction) (rate(writeagent_llm_tokens_total[1m]) * 60)",
          "legendFormat": "{{agent_id}} ({{direction}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Contradictions by Severity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (severity) (rate(writeagent_contradictions_total[5m]) * 60)",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Scene Generation Failures (cumulative)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "writeagent_scene_generation_failures_total",
          "legendFormat": "Total failures"
        }
      ]
    }
  ]
}
